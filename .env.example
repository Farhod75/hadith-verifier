# ============================================
# HADITH VERIFIER - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your keys
# NEVER commit .env.local to GitHub

# Anthropic Claude API
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase (for admin queue persistence)
# Get from: https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# App config
NEXT_PUBLIC_APP_NAME=Hadith Verifier
NEXT_PUBLIC_APP_URL=http://localhost:3000
