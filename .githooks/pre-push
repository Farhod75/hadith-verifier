#!/bin/sh
# .git/hooks/pre-push  v2 — hadith-verifier
# Smart: scans changed files, runs only relevant tests
# Excludes @real-api tagged tests (non-deterministic Claude calls)
#
# Doc-only push  → skip all tests instantly
# Code push      → targeted tests based on changed files
# @real-api tests → always skipped (run manually: --grep @real-api)
#
# Bypass: git push --no-verify

echo ""
echo "🔍 Smart pre-push scanner v2..."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# Get changed files vs remote
REMOTE_REF=$(git rev-parse --verify origin/main 2>/dev/null)
if [ -z "$REMOTE_REF" ]; then
  CHANGED_FILES=$(git diff --name-only $(git hash-object -t tree /dev/null) HEAD)
else
  CHANGED_FILES=$(git diff --name-only origin/main HEAD)
fi

if [ -z "$CHANGED_FILES" ]; then
  echo "✅ No changes — nothing to check"
  exit 0
fi

echo "📋 Changed: $(echo "$CHANGED_FILES" | wc -l | tr -d ' ') files"

# ── File classification ───────────────────────────────────────────────────────
DOC_PATTERNS="\.md$|fix_patterns|CLAUDE|AGENTS|QA_STANDARDS|CI_WORKFLOW|README|CHANGELOG|\.githooks|\.gitignore"
API_PATTERNS="^app/api/|route\.ts$"
UI_PATTERNS="^app/page\.tsx$|^components/|^lib/"
CONFIG_PATTERNS="next\.config|playwright\.config|tsconfig|package\.json$"

NON_DOC=$(echo "$CHANGED_FILES" | grep -vE "$DOC_PATTERNS" | wc -l | tr -d ' ')
HAS_API=$(echo "$CHANGED_FILES" | grep -E "$API_PATTERNS" | wc -l | tr -d ' ')
HAS_UI=$(echo "$CHANGED_FILES" | grep -E "$UI_PATTERNS" | wc -l | tr -d ' ')
HAS_CONFIG=$(echo "$CHANGED_FILES" | grep -E "$CONFIG_PATTERNS" | wc -l | tr -d ' ')

# ── Case 1: Doc-only — skip everything ───────────────────────────────────────
if [ "$NON_DOC" -eq 0 ]; then
  echo "✅ Doc-only push — skipping all tests"
  echo "   Files: $(echo "$CHANGED_FILES" | tr '\n' ' ')"
  exit 0
fi

echo "🔧 Code changes detected (API=$HAS_API UI=$HAS_UI Config=$HAS_CONFIG)"
echo ""

FAILED=0

# ── Always: TypeScript check ─────────────────────────────────────────────────
echo "▶ TypeScript check..."
npx tsc --noEmit 2>&1
if [ $? -ne 0 ]; then
  echo "❌ TypeScript errors"
  FAILED=1
fi
[ $FAILED -eq 0 ] && echo "✅ TypeScript OK"

# ── Config change: build check ────────────────────────────────────────────────
if [ "$HAS_CONFIG" -gt 0 ] && [ $FAILED -eq 0 ]; then
  echo "▶ Build check (config changed)..."
  npm run build 2>&1
  if [ $? -ne 0 ]; then echo "❌ Build failed"; FAILED=1; fi
  [ $FAILED -eq 0 ] && echo "✅ Build OK"
fi

# ── API route change: run api.spec.ts excluding @real-api ────────────────────
if [ "$HAS_API" -gt 0 ] && [ $FAILED -eq 0 ]; then
  echo "▶ API tests (excluding @real-api — non-deterministic Claude calls)..."
  # --grep-invert skips @real-api tagged tests
  npx playwright test tests/api.spec.ts \
    --project=chromium --reporter=list --workers=2 \
    --grep-invert "@real-api" 2>&1
  if [ $? -ne 0 ]; then echo "❌ API tests failed"; FAILED=1; fi
  [ $FAILED -eq 0 ] && echo "✅ API tests OK"
fi

# ── UI change: run E2E tests ──────────────────────────────────────────────────
if [ "$HAS_UI" -gt 0 ] && [ $FAILED -eq 0 ]; then
  echo "▶ E2E tests (UI changed)..."
  npx playwright test tests/hadith-verifier.spec.ts \
    --project=chromium --reporter=list --workers=2 2>&1
  if [ $? -ne 0 ]; then echo "❌ E2E tests failed"; FAILED=1; fi
  [ $FAILED -eq 0 ] && echo "✅ E2E tests OK"
fi

# ── Result ────────────────────────────────────────────────────────────────────
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
if [ $FAILED -ne 0 ]; then
  echo "❌ Push blocked — fix issues above"
  echo "   Emergency bypass: git push --no-verify"
  exit 1
else
  echo "✅ All checks passed — pushing!"
  exit 0
fi
