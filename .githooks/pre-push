#!/bin/sh
# .git/hooks/pre-push  v3 — hadith-verifier
# Smart scanner: runs only tests relevant to changed files
# Doc-only → instant skip. @real-api → always excluded.
#
# Test mapping:
#   app/api/tts/     → tts.spec.ts
#   app/api/analyze/ → api.spec.ts
#   app/page.tsx     → hadith-verifier.spec.ts
#   components/      → hadith-verifier.spec.ts
#   *.md / docs      → skip all (instant)
#
# Bypass: git push --no-verify

echo ""
echo "🔍 Smart pre-push scanner v3..."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

REMOTE_REF=$(git rev-parse --verify origin/main 2>/dev/null)
if [ -z "$REMOTE_REF" ]; then
  CHANGED_FILES=$(git diff --name-only $(git hash-object -t tree /dev/null) HEAD)
else
  CHANGED_FILES=$(git diff --name-only origin/main HEAD)
fi

if [ -z "$CHANGED_FILES" ]; then
  echo "✅ No changes — nothing to check"
  exit 0
fi

echo "📋 Changed: $(echo "$CHANGED_FILES" | wc -l | tr -d ' ') files"

# ── File classification ───────────────────────────────────────────────────────
DOC_PATTERNS="\.md$|fix_patterns|CLAUDE|AGENTS|QA_STANDARDS|CI_WORKFLOW|README|CHANGELOG|\.githooks|\.gitignore|\.txt$"
TTS_PATTERNS="^app/api/tts/|tts\.spec\.|TTSPlayer"
ANALYZE_PATTERNS="^app/api/analyze/|api\.spec\."
UI_PATTERNS="^app/page\.tsx$|^components/|^lib/"
CONFIG_PATTERNS="next\.config|playwright\.config|tsconfig|package\.json$"

NON_DOC=$(echo "$CHANGED_FILES" | grep -vE "$DOC_PATTERNS" | wc -l | tr -d ' ')
HAS_TTS=$(echo "$CHANGED_FILES" | grep -E "$TTS_PATTERNS" | wc -l | tr -d ' ')
HAS_ANALYZE=$(echo "$CHANGED_FILES" | grep -E "$ANALYZE_PATTERNS" | wc -l | tr -d ' ')
HAS_UI=$(echo "$CHANGED_FILES" | grep -E "$UI_PATTERNS" | wc -l | tr -d ' ')
HAS_CONFIG=$(echo "$CHANGED_FILES" | grep -E "$CONFIG_PATTERNS" | wc -l | tr -d ' ')

# ── Doc-only: skip instantly ──────────────────────────────────────────────────
if [ "$NON_DOC" -eq 0 ]; then
  echo "✅ Doc-only push — skipping all tests"
  exit 0
fi

echo "🔧 Code changes: TTS=$HAS_TTS Analyze=$HAS_ANALYZE UI=$HAS_UI Config=$HAS_CONFIG"
echo ""

FAILED=0

# ── Always: TypeScript ────────────────────────────────────────────────────────
echo "▶ TypeScript check..."
npx tsc --noEmit 2>&1
if [ $? -ne 0 ]; then echo "❌ TypeScript errors"; FAILED=1; fi
[ $FAILED -eq 0 ] && echo "✅ TypeScript OK"

# ── Config: build ─────────────────────────────────────────────────────────────
if [ "$HAS_CONFIG" -gt 0 ] && [ $FAILED -eq 0 ]; then
  echo "▶ Build check (config changed)..."
  npm run build 2>&1
  if [ $? -ne 0 ]; then echo "❌ Build failed"; FAILED=1; fi
  [ $FAILED -eq 0 ] && echo "✅ Build OK"
fi

# ── TTS route/component changed → run tts.spec.ts ────────────────────────────
if [ "$HAS_TTS" -gt 0 ] && [ $FAILED -eq 0 ]; then
  echo "▶ TTS contract tests (tts.spec.ts)..."
  npx playwright test tests/tts.spec.ts \
    --project=chromium --reporter=list --workers=2 \
    --grep-invert "@real-api" 2>&1
  if [ $? -ne 0 ]; then echo "❌ TTS tests failed"; FAILED=1; fi
  [ $FAILED -eq 0 ] && echo "✅ TTS tests OK"
fi

# ── Analyze route changed → run api.spec.ts ───────────────────────────────────
if [ "$HAS_ANALYZE" -gt 0 ] && [ $FAILED -eq 0 ]; then
  echo "▶ API tests (api.spec.ts, excluding @real-api)..."
  export MOCK_CLAUDE=1
  export BASE_URL=http://localhost:3011
  npx playwright test tests/api.spec.ts \
    --project=chromium --reporter=list --workers=2 \
    --grep-invert "@real-api" 2>&1
  API_RC=$?
  unset MOCK_CLAUDE BASE_URL
  if [ $API_RC -ne 0 ]; then echo "❌ API tests failed"; FAILED=1; fi
  [ $FAILED -eq 0 ] && echo "✅ API tests OK"
fi

# ── UI changed → run E2E ──────────────────────────────────────────────────────
if [ "$HAS_UI" -gt 0 ] && [ $FAILED -eq 0 ]; then
  echo "▶ E2E tests (hadith-verifier.spec.ts)..."
  export MOCK_CLAUDE=1
  export BASE_URL=http://localhost:3011
  npx playwright test tests/hadith-verifier.spec.ts \
    --project=chromium --reporter=list --workers=2 2>&1
  E2E_RC=$?
  unset MOCK_CLAUDE BASE_URL
  if [ $E2E_RC -ne 0 ]; then echo "❌ E2E tests failed"; FAILED=1; fi
  [ $FAILED -eq 0 ] && echo "✅ E2E tests OK"
fi

# ── Result ────────────────────────────────────────────────────────────────────
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
if [ $FAILED -ne 0 ]; then
  echo "❌ Push blocked — fix issues above"
  exit 1
else
  echo "✅ All checks passed — pushing!"
  exit 0
fi
